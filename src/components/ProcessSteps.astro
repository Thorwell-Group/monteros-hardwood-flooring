---
interface Step { step: string; detail: string; }
interface Props { steps: Step[]; heading?: string; subheading?: string; }
const { steps, heading = 'How It Works', subheading } = Astro.props as Props;
---
<section class="container-wide py-16">
  <div class="max-w-2xl mb-10">
    <h2 class="text-balance">{heading}</h2>
    {subheading && <p class="mt-3 text-lg text-slate-600">{subheading}</p>}
  </div>
  <ol class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {steps.map((s, i) => (
      <li class="card p-6">
        <div class="text-wood-500 font-display text-3xl font-bold mb-2">{String(i + 1).padStart(2, '0')}</div>
        <h3 class="text-lg font-semibold text-brand-900">{s.step}</h3>
        <p class="mt-2 text-sm text-slate-600">{s.detail}</p>
      </li>
    ))}
  </ol>
</section>
