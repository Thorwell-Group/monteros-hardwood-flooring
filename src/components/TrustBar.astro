---
import { business } from '~/data/business';
---
<section class="border-y border-slate-200 bg-brand-50/50">
  <div class="container-wide py-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      <div>
        <div class="text-2xl md:text-3xl font-display font-bold text-brand-800">{business.yearsInBusiness}+</div>
        <div class="text-xs uppercase tracking-wider text-slate-600 mt-1">Years In Business</div>
      </div>
      <div>
        <div class="text-2xl md:text-3xl font-display font-bold text-brand-800">{business.ratings.averageRating}★</div>
        <div class="text-xs uppercase tracking-wider text-slate-600 mt-1">{business.ratings.reviewCount}+ Reviews</div>
      </div>
      <div>
        <div class="text-2xl md:text-3xl font-display font-bold text-brand-800">Lifetime</div>
        <div class="text-xs uppercase tracking-wider text-slate-600 mt-1">Workmanship Guarantee</div>
      </div>
      <div>
        <div class="text-2xl md:text-3xl font-display font-bold text-brand-800">Free</div>
        <div class="text-xs uppercase tracking-wider text-slate-600 mt-1">In-Home Estimate</div>
      </div>
    </div>
  </div>
</section>
