---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import CTABanner from '~/components/CTABanner.astro';
import { blogPostingSchema, breadcrumbSchema } from '~/lib/schema';
import { formatDate } from '~/lib/formatting';
import { business } from '~/data/business';
import type { BlogPost } from '~/data/blog';

interface Props { post: BlogPost; html: string; }
const { post, html } = Astro.props as Props;
const path = `/blog/${post.slug}/`;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: post.title, href: path },
];

const schemas = [
  blogPostingSchema(post),
  breadcrumbSchema(crumbs),
];
---
<BaseLayout
  title={post.metaTitle}
  description={post.metaDesc}
  pathname={path}
  image={post.image}
  type="article"
  publishedTime={post.date}
  modifiedTime={post.date}
  schemas={schemas}
>
  <article>
    <header class="bg-brand-50 border-b border-slate-200">
      <div class="container-narrow py-12">
        <div class="mb-4"><Breadcrumbs items={crumbs} /></div>
        <div class="badge mb-4 capitalize">{post.category}</div>
        <h1 class="text-balance">{post.title}</h1>
        <div class="mt-4 flex items-center gap-3 text-sm text-slate-600">
          <span>By {business.brandName}</span>
          <span aria-hidden="true">·</span>
          <time datetime={post.date}>{formatDate(post.date)}</time>
          <span aria-hidden="true">·</span>
          <span>{post.readMins} min read</span>
        </div>
      </div>
    </header>

    <figure class="container-narrow mt-8">
      <img src={post.image} alt={post.alt} loading="eager" decoding="async" width="800" height="500" class="w-full rounded-xl bg-slate-100" />
    </figure>

    <section class="container-prose py-12 prose-brand" set:html={html}></section>

    {post.internalLinks.length > 0 && (
      <section class="container-narrow pb-8">
        <div class="card p-6 bg-brand-50/60 border-brand-200">
          <div class="text-xs uppercase tracking-wider text-brand-700 font-semibold">Continue reading</div>
          <ul class="mt-3 space-y-2 text-sm">
            {post.internalLinks.map((link) => (
              <li>→ <a href={link.href} class="font-semibold">{link.text}</a></li>
            ))}
          </ul>
        </div>
      </section>
    )}
  </article>

  <CTABanner />
</BaseLayout>
