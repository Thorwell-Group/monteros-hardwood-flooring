---
import '~/styles/global.css';
import MetaPixel from '~/components/MetaPixel.astro';
import { business } from '~/data/business';
import { buildSEO, type SEOInput } from '~/lib/seo';

interface Props extends SEOInput {
  bodyClass?: string;
  lang?: 'en' | 'es';
  /** Inject the GA4 gtag.js snippet. Opt-in so ad-landing pages (free-estimate)
      stay untouched; enabled on the booking pages so generate_lead can fire. */
  ga4?: boolean;
}

const { bodyClass = '', lang = 'en', ga4 = false, ...seoInput } = Astro.props as Props;
const seo = buildSEO({
  ...seoInput,
  pathname: seoInput.pathname ?? Astro.url.pathname,
  noindex: seoInput.noindex ?? true,
});

const t = lang === 'es'
  ? {
      tagline: 'Pisos de Madera',
      copyright: 'Derechos reservados',
      privacy: 'Privacidad',
      terms: 'Términos',
      designedBy: 'embudos diseñados y alojados por',
    }
  : {
      tagline: 'Hardwood Flooring',
      copyright: 'Copyright, all rights reserved',
      privacy: 'Privacy',
      terms: 'Terms',
      designedBy: 'funnels designed and hosted by',
    };
---
<!doctype html>
<html lang={lang} class="scroll-pt-20">
  <head>
    {ga4 && (
      <>
        {/* Google tag (gtag.js) — matches BaseLayout (G-MBZFMGB68K) so the
            generate_lead key event can fire on this booking page. */}
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-MBZFMGB68K"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-MBZFMGB68K');
        </script>
      </>
    )}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={business.brand.primaryColor} />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    {seo.noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={seo.type} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.image} />
    <meta property="og:site_name" content={business.brandName} />

    <link rel="icon" type="image/webp" href={business.brand.logo} />
    <link rel="apple-touch-icon" href={business.brand.logo} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.leadconnectorhq.com" crossorigin />
    <link rel="preconnect" href="https://link.msgsndr.com" crossorigin />
    <link rel="preconnect" href="https://connect.facebook.net" />
    <link rel="dns-prefetch" href="https://api.leadconnectorhq.com" />
    <link rel="dns-prefetch" href="https://link.msgsndr.com" />
    <link rel="preload" as="script" href="https://link.msgsndr.com/js/form_embed.js" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Raleway:wght@400;500&display=swap" rel="stylesheet" />

    <MetaPixel />

    {/* Ad attribution capture: reads UTMs + Meta click IDs from the URL/cookies,
        persists first-touch across funnel hops, and appends them to every GHL
        iframe src so the data lands on the contact. */}
    <script is:inline>
      (function () {
        var KEYS = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term',
                    'campaign_id','adset_id','ad_id','fbclid','fbc','fbp'];
        var STORE = 'tw_attrib';
        function getCookie(n){var m=document.cookie.match('(^|;)\\s*'+n+'\\s*=\\s*([^;]+)');return m?decodeURIComponent(m.pop()):'';}

        var params = new URLSearchParams(window.location.search), data = {};
        KEYS.forEach(function(k){ var v=params.get(k); if(v) data[k]=v; });
        var fbp=getCookie('_fbp'), fbc=getCookie('_fbc'), fbclid=params.get('fbclid')||'';
        if(!fbc && fbclid) fbc='fb.1.'+Date.now()+'.'+fbclid;
        if(fbclid) data.fbclid=fbclid; if(fbc) data.fbc=fbc; if(fbp) data.fbp=fbp;

        var stored={}; try{ stored=JSON.parse(localStorage.getItem(STORE)||'{}'); }catch(e){}
        var merged={}; KEYS.forEach(function(k){ merged[k]=data[k]||stored[k]||''; });
        if(fbp) merged.fbp=fbp; if(fbc) merged.fbc=fbc;
        try{ localStorage.setItem(STORE, JSON.stringify(merged)); }catch(e){}
        data = merged;

        function tagIframes(){
          document.querySelectorAll(
            'iframe[src*="/widget/survey/"],iframe[src*="/widget/booking/"],iframe[src*="/widget/form/"],' +
            'iframe[src*="leadconnectorhq.com"],iframe[src*="msgsndr.com"],iframe[src*="lc.thorwellgroup.com"]'
          ).forEach(function(f){
            if(f.getAttribute('data-tw')==='1') return;
            var src=f.getAttribute('src'); if(!src) return;
            var u; try{ u=new URL(src, window.location.origin);}catch(e){ return; }
            KEYS.forEach(function(k){ if(data[k] && !u.searchParams.has(k)) u.searchParams.set(k,data[k]); });
            f.setAttribute('data-tw','1');
            if(u.toString()!==src) f.setAttribute('src', u.toString());
          });
        }
        function fillInputs(){
          KEYS.forEach(function(k){ if(!data[k]) return;
            var el=document.querySelector('input[name="'+k+'"],input#'+k+',input[data-q="'+k+'"]');
            if(el){ el.value=data[k]; el.dispatchEvent(new Event('input',{bubbles:true})); el.dispatchEvent(new Event('change',{bubbles:true})); }
          });
        }
        function run(){ tagIframes(); fillInputs(); }
        try{ new MutationObserver(run).observe(document.documentElement,{childList:true,subtree:true}); }catch(e){}
        if(document.readyState!=='loading') run();
        document.addEventListener('DOMContentLoaded', run);
        setTimeout(run,1000); setTimeout(run,3000);
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <header class="bg-white border-b-2 border-brand-100">
      <div class="container-wide flex items-center justify-center h-[var(--header-h)]">
        <div class="flex items-center gap-3 select-none" aria-label={`${business.brandName}`}>
          <span class="relative inline-flex items-center justify-center h-14 w-14 md:h-16 md:w-16 rounded-2xl bg-white ring-2 ring-brand-200 shadow-md">
            <img src={business.brand.logo} alt={`${business.brandName} logo`} width="56" height="56" loading="eager" decoding="async" class="h-10 w-10 md:h-12 md:w-12 object-contain" />
          </span>
          <div class="leading-tight">
            <div class="font-display text-lg md:text-xl font-extrabold text-brand-900 tracking-tight">{business.shortName}</div>
            <div class="text-[11px] md:text-xs uppercase tracking-[0.18em] text-brand-600 font-semibold">{t.tagline}</div>
          </div>
        </div>
      </div>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class="bg-brand-950 text-slate-300 mt-16">
      <div class="container-wide py-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-slate-400">
          <div class="flex items-center gap-3">
            <img src={business.brand.logo} alt={business.brandName} width="32" height="32" loading="lazy" decoding="async" class="h-8 w-8 rounded-md bg-white p-1 shrink-0" />
            <div>{t.copyright}, {new Date().getFullYear()}</div>
          </div>
          <div class="flex items-center gap-5">
            <a href="/privacy/" class="hover:text-white">{t.privacy}</a>
            <a href="/terms/" class="hover:text-white">{t.terms}</a>
          </div>
          <a href="https://thorwellgroup.com" target="_blank" rel="noopener" class="md:text-right block group" style="font-family: 'Raleway', sans-serif; font-weight: 400;">
            <div class="text-[10px] text-slate-500 mb-1 leading-none">{t.designedBy}</div>
            <div class="text-sm text-slate-100 group-hover:text-white transition-colors leading-tight tracking-wide">
              Thor<span style="color: #CBFBB4;">w</span>ell Group
            </div>
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
