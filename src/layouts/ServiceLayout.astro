---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import TrustBar from '~/components/TrustBar.astro';
import ProcessSteps from '~/components/ProcessSteps.astro';
import FAQ from '~/components/FAQ.astro';
import CTABanner from '~/components/CTABanner.astro';
import AreaGrid from '~/components/AreaGrid.astro';
import { serviceSchema, breadcrumbSchema, faqSchema } from '~/lib/schema';
import type { Service } from '~/data/services';
import { business } from '~/data/business';

interface Props { service: Service; }
const { service } = Astro.props as Props;
const path = `/services/${service.slug}/`;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services/' },
  { name: service.shortName, href: path },
];

const schemas = [
  serviceSchema(service),
  breadcrumbSchema(crumbs),
  faqSchema(service.faqs),
];

const title = `${service.metaTitleBase} | Inland Empire`;
const description = service.metaDescBase;
---
<BaseLayout
  title={title}
  description={description}
  pathname={path}
  image={service.heroImage}
  schemas={schemas}
>
  <Hero
    eyebrow={`Inland Empire ${service.shortName}`}
    title={service.name}
    subtitle={service.oneLiner}
    image={service.heroImage}
    alt={service.altText}
  />

  <TrustBar />

  <section class="container-wide py-16">
    <div class="mb-4"><Breadcrumbs items={crumbs} /></div>

    {(() => {
      const photos = (service.gallery ?? []).filter((g) => g.src !== service.heroImage);
      const floats = [
        'md:float-right md:w-2/5 md:ml-8 md:mb-3 md:-mt-2 -rotate-2',
        'md:float-left  md:w-1/3 md:mr-8 md:mb-3 md:-mt-2 rotate-2',
        'md:float-right md:w-1/2 md:ml-8 md:mb-3 -rotate-1',
        'md:float-left  md:w-2/5 md:mr-8 md:mb-3 rotate-1',
        'md:float-right md:w-1/3 md:ml-8 md:mb-3 rotate-2',
        'md:float-left  md:w-1/3 md:mr-8 md:mb-3 -rotate-2',
      ];
      const figClass = (i: number) => `not-prose ${floats[i % floats.length]} mb-6 transition-transform duration-500 hover:rotate-0 hover:scale-[1.02]`;
      const Fig = (i: number) => photos[i] ? (
        <figure class={figClass(i)} data-reveal={i % 2 === 0 ? 'right' : 'left'} data-reveal-delay="100">
          <img src={photos[i].src} alt={photos[i].alt} loading="lazy" decoding="async" class="w-full rounded-2xl shadow-2xl ring-1 ring-brand-100" />
        </figure>
      ) : null;
      return (
        <div class="prose-brand max-w-4xl flow-root">
          <h2>{service.name} Across the Inland Empire</h2>

          {Fig(0)}
          <p>{service.oneLiner}</p>
          <p>For {business.yearsInBusiness}+ years, {business.brandName} has been the family-owned flooring crew Inland Empire homeowners call when they want it done right the first time. Every job comes with a written, itemized estimate, on-time crews, daily clean-up, and a lifetime workmanship guarantee.</p>
          <p>From bungalows in Redlands to new builds in Eastvale, our crew works the same way every time: respect the home, respect the schedule, and leave a floor that looks better than the day it was installed. Most of our work comes from neighbors who watched us finish a friend's project and called us next.</p>

          {Fig(1)}
          <h3>What's Included</h3>
          <ul>
            {service.benefits.map((b) => <li>{b}</li>)}
          </ul>

          {Fig(2)}
          <p>Every {service.shortName.toLowerCase()} project starts the same way - a free, in-home walk-through where we measure, talk through species and finish, and answer every question you have. No rushed quotes, no high-pressure sales script. The estimate you sign is the price you pay.</p>

          {service.materials && service.materials.length > 0 && (
            <>
              {Fig(3)}
              <h3>Materials We Carry</h3>
              <ul>{service.materials.map((m) => <li>{m}</li>)}</ul>
            </>
          )}

          {Fig(4)}
          <h3>Why Inland Empire Homes Choose Us</h3>
          <p>Hot, dry summers and cool, damp winters chew through cheaply installed floors. We acclimate every board on-site, moisture-test the subfloor, and choose the right adhesive or fastener pattern for the climate - the kind of detail that separates a floor that lasts decades from one that cups, gaps, or peaks in two summers.</p>

          {Fig(5)}
          <p>Whether you're matching a 1950's parquet, fitting wide-plank European oak, or putting waterproof LVP into a busy family kitchen, the same crew shows up with the same standards. That consistency is why we still get calls from customers we worked for fifteen years ago.</p>

          <div class="clear-both"></div>

          <div class="not-prose mt-10 flex flex-wrap gap-3">
            <a href="/contact/" class="btn-primary">Get a Free Estimate</a>
            <a href={`tel:${business.phoneE164}`} class="btn-secondary">Call {business.phoneDisplay}</a>
          </div>
        </div>
      );
    })()}
  </section>

  <div class="bg-slate-50">
    <ProcessSteps steps={service.process} heading={`Our ${service.shortName} Process`} subheading="Every project follows the same clear, predictable steps from estimate to walk-through." />
  </div>

  <FAQ faqs={service.faqs} heading={`${service.shortName} FAQ`} />

  <AreaGrid heading="Areas We Serve" subheading={`We bring ${service.shortName.toLowerCase()} to homes across the Inland Empire - find your city.`} />

  <CTABanner />
</BaseLayout>
