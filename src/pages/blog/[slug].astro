---
import BlogLayout from '~/layouts/BlogLayout.astro';
import { blogPosts } from '~/data/blog';
import { faqSchema } from '~/lib/schema';
import { marked } from 'marked';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const html = marked.parse(post.body, { async: false }) as string;

// Posts that define an `faqs` array also emit FAQPage structured data.
// Rendered here (not in BlogLayout) so the existing BlogPosting + Breadcrumb
// JSON-LD on every post stays untouched. JSON-LD is valid anywhere in the doc.
const faqLd = post.faqs && post.faqs.length > 0 ? faqSchema(post.faqs) : null;
---
<BlogLayout post={post} html={html} />
{faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
